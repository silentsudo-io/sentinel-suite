<!-- Midnight -->
<ResourceDictionary	xmlns		="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x		="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:po	="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

	<LinearGradientBrush	po:Freeze="true"	x:Key="ChartTrader.ButtonBackground" StartPoint="0.5,-0.05"	EndPoint="0.5,0.66">
		<LinearGradientBrush.GradientStops>
			<GradientStop Color="#150C24" Offset="0"/>
			<GradientStop Color="#150C24" Offset="1"/>
		</LinearGradientBrush.GradientStops>
	</LinearGradientBrush>
	<LinearGradientBrush	po:Freeze="true"	x:Key="ChartTrader.ActionButtonsBackground" StartPoint="0.5,-0.05"	EndPoint="0.5,0.66">
		<LinearGradientBrush.GradientStops>
			<GradientStop Color="#150C24" Offset="0"/>
			<GradientStop Color="#150C24" Offset="1"/>
		</LinearGradientBrush.GradientStops>
	</LinearGradientBrush>
	<LinearGradientBrush	po:Freeze="true"	x:Key="ChartTrader.BuyButtonsBackground" StartPoint="0.5,-0.05"	EndPoint="0.5,0.66"><!-- Sentinel up (deep) -->
		<LinearGradientBrush.GradientStops>
			<GradientStop Color="#1C8F63" Offset="0"/>
			<GradientStop Color="#125C41" Offset="1"/>
		</LinearGradientBrush.GradientStops>
	</LinearGradientBrush>
	<LinearGradientBrush	po:Freeze="true"	x:Key="ChartTrader.SellButtonsBackground" StartPoint="0.5,-0.05"	EndPoint="0.5,0.66"><!-- Sentinel down (deep) -->
		<LinearGradientBrush.GradientStops>
			<GradientStop Color="#B84550" Offset="0"/>
			<GradientStop Color="#7E2C34" Offset="1"/>
		</LinearGradientBrush.GradientStops>
	</LinearGradientBrush>
	<SolidColorBrush	x:Key="ChartControl.ChartBackground"				Color="#FF0B0714"			po:Freeze="true" /><!-- Sentinel Neon: violet-black night price panel. This exact hex #0B0714 is the KEY the SentinelSkin skin-follow glue matches on — do NOT retune it without updating SkinBgTheme in AddOns\SentinelSkin.cs -->

	<SolidColorBrush	x:Key="ChartControl.ChartText"						Color="#FFE9E1F5"		po:Freeze="true" /><!-- Sentinel Neon: lavender ink -->
	<SolidColorBrush	x:Key="ChartControl.InactivePriceMarkersBackground"	Color="#FF150C24"			po:Freeze="true" />
	<SolidColorBrush	x:Key="ChartControl.CrosshairLabelBackground"		Color="#FF150C24"			po:Freeze="true" />

	<Pen				x:Key="ChartControl.AxisPen"						Brush="#FF7A6AA0"		po:Freeze="true"	Thickness="1"/>
	<Pen				x:Key="ChartControl.CrosshairPen"					Brush="#FF7A6AA0"		po:Freeze="true"	Thickness="1"/>
	<Pen				x:Key="ChartControl.GridLineHPen"											po:Freeze="true"	Thickness="1">
		<Pen.Brush>
			<SolidColorBrush Color="#2A1A48" Opacity="1" po:Freeze="true"></SolidColorBrush><!-- Sentinel Neon: gridlines LIFTED above the violet-black panel (a violet grid is the theme's signature) -->
		</Pen.Brush>
	</Pen>
	<Pen				x:Key="ChartControl.GridLineVPen"					po:Freeze="true"	Thickness="1">
		<Pen.Brush>
			<SolidColorBrush Color="#2A1A48" Opacity="1" po:Freeze="true"></SolidColorBrush><!-- Sentinel Neon: gridlines LIFTED above the violet-black panel (a violet grid is the theme's signature) -->
		</Pen.Brush>
	</Pen>
	<Pen				x:Key="ChartControl.PanelSplitterPen"				Brush="#FF7A6AA0"		po:Freeze="true"		Thickness="1"/>

	<SolidColorBrush	x:Key="ChartControl.DataBoxPanelLabelBackground"	Color="#FF1E1234"		po:Freeze="true" />
	<SolidColorBrush	x:Key="ChartControl.DataBoxItemLabelBackground"		Color="#FF6A5C8E"		po:Freeze="true" />
	<SolidColorBrush	x:Key="ChartControl.DataBoxBackground"				Color="#FF0B0714"			po:Freeze="true"		Opacity="0.75"/>
	<SolidColorBrush	x:Key="ChartControl.DataBoxForeground"				Color="#FFC3B2E8"		po:Freeze="true" />
	<SolidColorBrush	x:Key="ChartControl.TimeHighBrush"					Color="#FFC13BFF"			po:Freeze="true"		Opacity="0.25"/><!-- Sentinel Neon: electric violet accent -->
	<SolidColorBrush	x:Key="ChartControl.DropHighlight"					Color="#A64BFF"			po:Freeze="true"		Opacity="0.5"/>
	<SolidColorBrush	x:Key="ChartControl.SelectedMarkerBrush"			Color="#FFC13BFF"	po:Freeze="true" /><!-- Sentinel Neon: electric violet accent -->
	<SolidColorBrush	x:Key="ChartControl.UpBrush"						Color="#FF009999"		po:Freeze="true" /><!-- Sentinel: teal up bars (user pick) -->
	<SolidColorBrush	x:Key="ChartControl.DownBrush"						Color="#FF8E8E8E"				po:Freeze="true" /><!-- Sentinel: grey down bars (user pick) -->
	<SolidColorBrush	x:Key="ChartControl.VolumetricText"					Color="#FFF4EEFF"			po:Freeze="true" />
	<Pen				x:Key="ChartControl.Stroke"							Brush="#FF009999"		po:Freeze="true"		Thickness="1"/><!-- outline matches up body -->
	<Pen				x:Key="ChartControl.Stroke2"						Brush="#FF8E8E8E"		po:Freeze="true"		Thickness="1"/><!-- outline matches down body -->
</ResourceDictionary>
