<!-- Brushed Steel — the Sentinel SILVER chart skin (graphite mid-tone; light text, metallic cyan) -->
<ResourceDictionary	xmlns		="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x		="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:po	="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

	<LinearGradientBrush	po:Freeze="true"	x:Key="ChartTrader.ButtonBackground" StartPoint="0.5,-0.05"	EndPoint="0.5,0.66">
		<LinearGradientBrush.GradientStops>
			<GradientStop Color="#3A414C" Offset="0"/>
			<GradientStop Color="#3A414C" Offset="1"/>
		</LinearGradientBrush.GradientStops>
	</LinearGradientBrush>
	<LinearGradientBrush	po:Freeze="true"	x:Key="ChartTrader.ActionButtonsBackground" StartPoint="0.5,-0.05"	EndPoint="0.5,0.66">
		<LinearGradientBrush.GradientStops>
			<GradientStop Color="#3A414C" Offset="0"/>
			<GradientStop Color="#3A414C" Offset="1"/>
		</LinearGradientBrush.GradientStops>
	</LinearGradientBrush>
	<LinearGradientBrush	po:Freeze="true"	x:Key="ChartTrader.BuyButtonsBackground" StartPoint="0.5,-0.05"	EndPoint="0.5,0.66"><!-- Sentinel up (deep) -->
		<LinearGradientBrush.GradientStops>
			<GradientStop Color="#1C8F63" Offset="0"/>
			<GradientStop Color="#125C41" Offset="1"/>
		</LinearGradientBrush.GradientStops>
	</LinearGradientBrush>
	<LinearGradientBrush	po:Freeze="true"	x:Key="ChartTrader.SellButtonsBackground" StartPoint="0.5,-0.05"	EndPoint="0.5,0.66"><!-- Sentinel down (deep) -->
		<LinearGradientBrush.GradientStops>
			<GradientStop Color="#B84550" Offset="0"/>
			<GradientStop Color="#7E2C34" Offset="1"/>
		</LinearGradientBrush.GradientStops>
	</LinearGradientBrush>
	<SolidColorBrush	x:Key="ChartControl.ChartBackground"				Color="#FF2A2F38"			po:Freeze="true" /><!-- Sentinel Silver: brushed-graphite price panel (mid-tone between navy Dark and grey Light) -->
	<SolidColorBrush	x:Key="ChartControl.ChartText"						Color="#FFE8ECF2"		po:Freeze="true" /><!-- light steel text -->
	<SolidColorBrush	x:Key="ChartControl.InactivePriceMarkersBackground"	Color="#FF3E4652"			po:Freeze="true" />
	<SolidColorBrush	x:Key="ChartControl.CrosshairLabelBackground"		Color="#FF3E4652"			po:Freeze="true" />

	<Pen				x:Key="ChartControl.AxisPen"						Brush="#FF6E7A8A"		po:Freeze="true"	Thickness="1"/>
	<Pen				x:Key="ChartControl.CrosshairPen"					Brush="#FF6E7A8A"		po:Freeze="true"	Thickness="1"/>
	<Pen				x:Key="ChartControl.GridLineHPen"											po:Freeze="true"	Thickness="1">
		<Pen.Brush>
			<SolidColorBrush Color="#343B46" Opacity="1" po:Freeze="true"></SolidColorBrush>
		</Pen.Brush>
	</Pen>
	<Pen				x:Key="ChartControl.GridLineVPen"					po:Freeze="true"	Thickness="1">
		<Pen.Brush>
			<SolidColorBrush Color="#343B46" Opacity="1" po:Freeze="true"></SolidColorBrush>
		</Pen.Brush>
	</Pen>
	<Pen				x:Key="ChartControl.PanelSplitterPen"				Brush="#FF556070"		po:Freeze="true"		Thickness="1"/>

	<SolidColorBrush	x:Key="ChartControl.DataBoxPanelLabelBackground"	Color="#FF3E4652"		po:Freeze="true" />
	<SolidColorBrush	x:Key="ChartControl.DataBoxItemLabelBackground"		Color="#FF4A5462"		po:Freeze="true" />
	<SolidColorBrush	x:Key="ChartControl.DataBoxBackground"				Color="#FF2A2F38"			po:Freeze="true"		Opacity="0.8"/>
	<SolidColorBrush	x:Key="ChartControl.DataBoxForeground"				Color="#FFB2BCC9"		po:Freeze="true" />
	<SolidColorBrush	x:Key="ChartControl.TimeHighBrush"					Color="#FF50D6E4"			po:Freeze="true"		Opacity="0.22"/>
	<SolidColorBrush	x:Key="ChartControl.DropHighlight"					Color="#4488CC"			po:Freeze="true"		Opacity="0.5"/>
	<SolidColorBrush	x:Key="ChartControl.SelectedMarkerBrush"			Color="#FF50D6E4"	po:Freeze="true" />
	<SolidColorBrush	x:Key="ChartControl.UpBrush"						Color="#FF009999"		po:Freeze="true" /><!-- teal up bars -->
	<SolidColorBrush	x:Key="ChartControl.DownBrush"						Color="#FF9AA0AA"				po:Freeze="true" /><!-- lightened grey down bars (reads on graphite) -->
	<SolidColorBrush	x:Key="ChartControl.VolumetricText"					Color="#FFE8ECF2"			po:Freeze="true" />
	<Pen				x:Key="ChartControl.Stroke"							Brush="#FF009999"		po:Freeze="true"		Thickness="1"/><!-- outline matches up body -->
	<Pen				x:Key="ChartControl.Stroke2"						Brush="#FF9AA0AA"		po:Freeze="true"		Thickness="1"/><!-- outline matches down body -->
</ResourceDictionary>
