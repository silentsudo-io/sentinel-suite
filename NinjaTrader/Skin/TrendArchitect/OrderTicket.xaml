<!-- TrendArchitect Skin — OrderTicket.xaml                       -->
<!-- Detached order ticket window styling                         -->
<!-- ============================================================ -->
<ResourceDictionary xmlns    ="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x  ="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:po ="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

    <SolidColorBrush x:Key="OrderTicket.ButtonBackground"         Color="#FF13161E" po:Freeze="true" />
    <SolidColorBrush x:Key="OrderTicket.BuyButtonsBackground"     Color="#0D1F1A"   po:Freeze="true" />
    <SolidColorBrush x:Key="OrderTicket.SellButtonsBackground"    Color="#1F0D10"   po:Freeze="true" />

</ResourceDictionary>
